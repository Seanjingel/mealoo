              ]
            }
          }
        },
        {
          "name": "Confirm UPI Payment (shortcut)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/test/payment/confirm?phone={{phone}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "test", "payment", "confirm"],
              "query": [{ "key": "phone", "value": "{{phone}}" }]
            },
            "description": "Triggers confirmUpiPayment — same as the real payment webhook but via test path."
          }
        },
        {
          "name": "Inspect Session State",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/test/session/{{phone}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "test", "session", "{{phone}}"]
            },
            "description": "Returns current session: state, cart size, selected restaurant/category, delivery address, payment method."
          }
        },
        {
          "name": "List All Active Sessions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/test/sessions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "test", "sessions"]
            },
            "description": "Returns count + phone numbers of all in-memory sessions."
          }
        },
        {
          "name": "Reset Session",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/test/session/{{phone}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "test", "session", "{{phone}}"]
            },
            "description": "Clears the session for this phone number — customer starts fresh from SELECT_RESTAURANT."
          }
        }
      ]
    },

    {
      "name": "Actuator",
      "description": "Spring Boot Actuator monitoring endpoints.",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/actuator/health", "host": ["{{baseUrl}}"], "path": ["actuator", "health"] },
            "description": "Returns UP/DOWN status with component details."
          }
        },
        {
          "name": "Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/actuator/info", "host": ["{{baseUrl}}"], "path": ["actuator", "info"] },
            "description": "Returns app name, version, description from application.properties info.* keys."
          }
        },
        {
          "name": "Metrics — JVM Memory Used",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/actuator/metrics/jvm.memory.used", "host": ["{{baseUrl}}"], "path": ["actuator", "metrics", "jvm.memory.used"] }
          }
        },
        {
          "name": "Metrics — HTTP Request Count",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/actuator/metrics/http.server.requests", "host": ["{{baseUrl}}"], "path": ["actuator", "metrics", "http.server.requests"] }
          }
        },
        {
          "name": "Metrics — List All",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/actuator/metrics", "host": ["{{baseUrl}}"], "path": ["actuator", "metrics"] },
            "description": "Lists all available metric names."
          }
        },
        {
          "name": "Loggers — View com.mealoo level",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/actuator/loggers/com.mealoo", "host": ["{{baseUrl}}"], "path": ["actuator", "loggers", "com.mealoo"] },
            "description": "Returns effective log level for the com.mealoo package."
          }
        },
        {
          "name": "Loggers — Set com.mealoo to TRACE",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"configuredLevel\": \"TRACE\" }" },
            "url": { "raw": "{{baseUrl}}/actuator/loggers/com.mealoo", "host": ["{{baseUrl}}"], "path": ["actuator", "loggers", "com.mealoo"] },
            "description": "Dynamically change log level to TRACE without restarting. Change to DEBUG/INFO/WARN to dial back."
          }
        },
        {
          "name": "Environment",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/actuator/env", "host": ["{{baseUrl}}"], "path": ["actuator", "env"] },
            "description": "Returns all resolved properties. Sensitive values like access tokens are masked."
          }
        }
      ]
    }
  ]
}
